# TrainerMate local API settings
# Copy the relevant lines into .env and fill in the real values.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required for forgot-password emails when running the API locally at 127.0.0.1:8000.
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=support@trainermate.xyz
RESEND_FROM_NAME=TrainerMate Support

# Optional: point the desktop dashboard at a deployed HTTPS API instead of the local API.
# TRAINERMATE_API_URL=https://your-render-service.onrender.com
